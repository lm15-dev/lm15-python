    },
    {
      "id": "gemini.response.prompt_feedback_blocked",
      "provider": "gemini",
      "request": {
        "model": "gemini-2.0-flash-lite",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "response": {
        "promptFeedback": {
          "blockReason": "SAFETY"
        }
      },
      "expected": {
        "class": "InvalidRequestError",
        "canonical_code": "invalid_request",
        "message_contains": [
          "Prompt blocked: SAFETY"
        ]
      }
    },
    {
      "id": "gemini.response.finish_reason_blocked",
      "provider": "gemini",
      "request": {
        "model": "gemini-2.0-flash-lite",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "response": {
        "candidates": [
          {
            "finishReason": "RECITATION",
            "finishMessage": "recitation detected"
          }
        ]
      },
      "expected": {
        "class": "InvalidRequestError",
        "canonical_code": "invalid_request",
        "message_contains": [
          "recitation detected"
        ]
      }
    }
  ]
}
