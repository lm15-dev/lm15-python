        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "raw_event": {
        "data": "{\"type\":\"error\",\"error\":{\"type\":\"overloaded_error\",\"message\":\"busy\"}}"
      },
      "expected_event": {
        "type": "error",
        "error": {
          "code": "server",
          "provider_code": "overloaded_error",
          "message": "busy"
        }
      }
    },
    {
      "id": "anthropic.stream.server_top_level",
      "provider": "anthropic",
      "request": {
        "model": "claude-sonnet-4-5",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "raw_event": {
        "data": "{\"type\":\"error\",\"code\":\"api_error\",\"message\":\"boom\"}"
      },
      "expected_event": {
        "type": "error",
        "error": {
          "code": "server",
          "provider_code": "api_error",
          "message": "boom"
        }
      }
    },
    {
      "id": "gemini.stream.rate_limit",
      "provider": "gemini",
      "request": {
        "model": "gemini-2.0-flash-lite",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "raw_event": {
        "data": "{\"error\":{\"status\":\"RESOURCE_EXHAUSTED\",\"message\":\"quota hit\"}}"
      },
      "expected_event": {
        "type": "error",
        "error": {
          "code": "rate_limit",
          "provider_code": "RESOURCE_EXHAUSTED",
          "message": "quota hit"
        }
      }
    },
    {
      "id": "gemini.stream.blocked_prompt",
      "provider": "gemini",
      "request": {
        "model": "gemini-2.0-flash-lite",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "raw_event": {
        "data": "{\"promptFeedback\":{\"blockReason\":\"BLOCKLIST\"}}"
      },
      "expected_event": {
        "type": "error",
        "error": {
          "code": "invalid_request",
          "provider_code": "inband_finish_reason",
          "message": "Prompt blocked: BLOCKLIST"
        }
      }
    }
  ],
  "inband_response_error_cases": [
    {
      "id": "openai.response.invalid_image",
      "provider": "openai",
      "request": {
        "model": "gpt-4.1-mini",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "response": {
        "error": {
          "code": "invalid_image",
          "message": "bad image"
        }
      },
      "expected": {
        "class": "InvalidRequestError",
        "canonical_code": "invalid_request",
        "message_contains": [
          "bad image"
        ]
      }
    },
    {
      "id": "openai.response.vector_store_timeout",
      "provider": "openai",
      "request": {
        "model": "gpt-4.1-mini",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "response": {
        "error": {
          "code": "vector_store_timeout",
          "message": "timed out"
        }
      },
      "expected": {
        "class": "TimeoutError",
        "canonical_code": "timeout",
        "message_contains": [
          "timed out"
