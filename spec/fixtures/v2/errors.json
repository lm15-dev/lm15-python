{
  "fixture_version": "1.0.0",
  "contract_version": "v2",
  "kind": "errors",
  "http_status_cases": [
    {
      "id": "http.401",
      "status": 401,
      "message": "bad key",
      "expected": {
        "class": "AuthError",
        "canonical_code": "auth"
      }
    },
    {
      "id": "http.403",
      "status": 403,
      "message": "forbidden",
      "expected": {
        "class": "AuthError",
        "canonical_code": "auth"
      }
    },
    {
      "id": "http.402",
      "status": 402,
      "message": "billing",
      "expected": {
        "class": "BillingError",
        "canonical_code": "billing"
      }
    },
    {
      "id": "http.408",
      "status": 408,
      "message": "timeout",
      "expected": {
        "class": "TimeoutError",
        "canonical_code": "timeout"
      }
    },
    {
      "id": "http.504",
      "status": 504,
      "message": "gateway timeout",
      "expected": {
        "class": "TimeoutError",
        "canonical_code": "timeout"
      }
    },
    {
      "id": "http.429",
      "status": 429,
      "message": "slow down",
      "expected": {
        "class": "RateLimitError",
        "canonical_code": "rate_limit"
      }
    },
    {
      "id": "http.400",
      "status": 400,
      "message": "bad request",
      "expected": {
        "class": "InvalidRequestError",
        "canonical_code": "invalid_request"
      }
    },
    {
      "id": "http.422",
      "status": 422,
      "message": "unprocessable",
      "expected": {
        "class": "InvalidRequestError",
        "canonical_code": "invalid_request"
      }
    },
    {
      "id": "http.500",
      "status": 500,
      "message": "boom",
      "expected": {
        "class": "ServerError",
        "canonical_code": "server"
      }
    },
    {
      "id": "http.503",
      "status": 503,
      "message": "unavailable",
      "expected": {
        "class": "ServerError",
        "canonical_code": "server"
      }
    }
  ],
  "normalize_error_cases": [
    {
      "id": "openai.invalid_api_key",
      "provider": "openai",
      "status": 401,
      "body": {
        "error": {
          "message": "bad key",
          "code": "invalid_api_key",
          "type": "authentication_error"
        }
      },
      "expected": {
        "class": "AuthError",
        "canonical_code": "auth",
        "message_contains": [
          "bad key"
        ]
      }
    },
    {
      "id": "openai.insufficient_quota",
      "provider": "openai",
      "status": 429,
      "body": {
        "error": {
          "message": "quota hit",
          "code": "insufficient_quota",
          "type": "insufficient_quota"
        }
      },
      "expected": {
        "class": "BillingError",
        "canonical_code": "billing",
        "message_contains": [
          "quota hit"
        ]
      }
    },
    {
      "id": "openai.context_length",
      "provider": "openai",
      "status": 400,
      "body": {
        "error": {
          "message": "too many tokens",
          "code": "context_length_exceeded"
        }
      },
      "expected": {
        "class": "ContextLengthError",
        "canonical_code": "context_length",
        "message_contains": [
          "too many tokens"
        ]
      }
    },
    {
      "id": "anthropic.context_length",
      "provider": "anthropic",
      "status": 400,
      "body": {
        "type": "error",
        "error": {
          "type": "invalid_request_error",
          "message": "Input context length exceeded token limit."
        },
        "request_id": "req_123"
      },
      "expected": {
        "class": "ContextLengthError",
        "canonical_code": "context_length",
        "message_contains": [
          "req_123"
        ]
      }
    },
    {
      "id": "anthropic.rate_limit",
      "provider": "anthropic",
      "status": 429,
      "body": {
        "type": "error",
        "error": {
          "type": "rate_limit_error",
          "message": "Too many requests"
        }
      },
      "expected": {
        "class": "RateLimitError",
        "canonical_code": "rate_limit",
        "message_contains": [
          "Too many requests"
        ]
      }
    },
    {
      "id": "gemini.rate_limit",
      "provider": "gemini",
      "status": 429,
      "body": {
        "error": {
          "message": "quota hit",
          "status": "RESOURCE_EXHAUSTED",
          "code": 429
        }
      },
      "expected": {
        "class": "RateLimitError",
        "canonical_code": "rate_limit",
        "message_contains": [
          "quota hit"
        ]
      }
    },
    {
      "id": "gemini.context_length",
      "provider": "gemini",
      "status": 429,
      "body": {
        "error": {
          "message": "Input token limit exceeded.",
          "status": "RESOURCE_EXHAUSTED",
          "code": 429
        }
      },
      "expected": {
        "class": "ContextLengthError",
        "canonical_code": "context_length",
        "message_contains": [
          "Input token limit exceeded."
        ]
      }
    },
    {
      "id": "gemini.invalid_argument",
      "provider": "gemini",
      "status": 400,
      "body": {
        "error": {
          "message": "bad request",
          "status": "INVALID_ARGUMENT",
          "code": 400
        }
      },
      "expected": {
        "class": "InvalidRequestError",
        "canonical_code": "invalid_request",
        "message_contains": [
          "bad request"
        ]
      }
    }
  ],
  "stream_error_cases": [
    {
      "id": "openai.stream.rate_limit",
      "provider": "openai",
      "request": {
        "model": "gpt-4.1-mini",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "raw_event": {
        "data": "{\"type\":\"response.error\",\"code\":\"rate_limit_exceeded\",\"message\":\"slow down\"}"
      },
      "expected_event": {
        "type": "error",
        "error": {
          "code": "rate_limit",
          "provider_code": "rate_limit_exceeded",
          "message": "slow down"
        }
      }
    },
    {
      "id": "openai.stream.server",
      "provider": "openai",
      "request": {
        "model": "gpt-4.1-mini",
        "messages": [
          {
            "role": "user",
            "parts": [
              {
                "type": "text",
                "text": "hi"
              }
            ]
          }
        ]
      },
      "raw_event": {
        "data": "{\"type\":\"error\",\"error\":{\"code\":\"server_error\",\"message\":\"boom\"}}"
      },
      "expected_event": {
        "type": "error",
        "error": {
          "code": "server",
          "provider_code": "server_error",
          "message": "boom"
        }
      }
    },
    {
      "id": "anthropic.stream.server_nested",
