{
  "id": "anthropic.streaming",
  "provider": "anthropic",
  "feature": "streaming",
  "description": "Streaming response with stream: true",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Hello."
            }
          ]
        }
      ],
      "max_tokens": 256,
      "stream": true
    }
  },
  "expect": {
    "status": 200
  },
  "expect_lm15": {
    "parts": {
      "text": {
        "min": 1
      }
    },
    "finish_reason": "stop",
    "usage": {
      "required": true
    }
  }
}
