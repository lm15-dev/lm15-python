{
  "id": "openai.file_input",
  "provider": "openai",
  "feature": "file_input",
  "description": "File/PDF input via file object",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "What are the two words in this PDF? Reply with only those two words."
            },
            {
              "type": "input_file",
              "filename": "file.pdf",
              "file_data": "data:application/pdf;base64,"
            }
          ]
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
